# Copy to `.env` and adjust for your environment. All are optional in
# development; production should set at least the first three.

# Set to 0 in production to enable security hardening.
DJANGO_DEBUG=1

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me

# Comma-separated list of hostnames the site may serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated https origins trusted for CSRF (e.g. https://yourapp.onrender.com)
DJANGO_CSRF_TRUSTED_ORIGINS=

# Postgres connection string. If unset, SQLite is used.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
